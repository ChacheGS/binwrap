#!/usr/bin/env bash

HANDLER_DIR="${WRAPPER_HANDLER_DIR:-$(cd "$(dirname "$0")/handlers" && pwd)}"
CLAUDE_EXTENSIONS_HOME="${CLAUDE_EXTENSIONS_HOME:-$HOME/.config/claude/extensions}"
CLAUDE_ARGS=()
WRAPPER_ERROR=""

while [[ $# -gt 0 ]]; do
    arg="$1"
    shift

    if [[ "$arg" == --* ]]; then
        flag_name="${arg#--}"

        if [[ ! "$flag_name" =~ ^[a-zA-Z0-9_-]+$ ]]; then
            CLAUDE_ARGS+=("$arg")
            continue
        fi

        handler="$HANDLER_DIR/${flag_name}.sh"

        if [[ -f "$handler" ]]; then
            # shellcheck source=/dev/null
            source "$handler"
            continue
        fi
    fi

    CLAUDE_ARGS+=("$arg")
done

if [[ -n "$WRAPPER_ERROR" ]]; then
    echo "claude-wrapper: $WRAPPER_ERROR" >&2
    exit 1
fi

exec command claude "${CLAUDE_ARGS[@]}"
