#!/usr/bin/env bash

if [[ $# -eq 0 ]]; then
    echo "binwrap: usage: binwrap <binary> [args...]" >&2
    exit 1
fi

BINWRAP_BINARY="$1"
shift

if [[ ! "$BINWRAP_BINARY" =~ ^[a-zA-Z0-9_-]+$ ]]; then
    echo "binwrap: invalid binary name '${BINWRAP_BINARY}'" >&2
    exit 1
fi

if ! command -v "$BINWRAP_BINARY" &>/dev/null; then
    echo "binwrap: binary '${BINWRAP_BINARY}' not found in PATH" >&2
    exit 1
fi

BINWRAP_HOME="${BINWRAP_HOME:-$HOME/.config/binwrap}"
HANDLER_DIR="${BINWRAP_HOME}/${BINWRAP_BINARY}"
WRAPPED_BIN_ARGS=()
WRAPPER_ERROR=""

while [[ $# -gt 0 ]]; do
    arg="$1"
    shift

    if [[ "$arg" == --* ]]; then
        flag_name="${arg#--}"

        if [[ ! "$flag_name" =~ ^[a-zA-Z0-9_-]+$ ]]; then
            WRAPPED_BIN_ARGS+=("$arg")
            continue
        fi

        handler="$HANDLER_DIR/${flag_name}.sh"

        if [[ -f "$handler" ]]; then
            _orig_argc=$#
            _sandbox_result=$(
                WRAPPED_BIN_ARGS=()
                WRAPPER_ERROR=""
                # shellcheck source=/dev/null
                source "$handler"
                printf 'WRAPPER_ERROR=%q\n' "$WRAPPER_ERROR"
                printf '_h_consumed=%d\n' $(( _orig_argc - $# ))
                printf '_h_new_args=('
                [[ ${#WRAPPED_BIN_ARGS[@]} -gt 0 ]] && printf '%q ' "${WRAPPED_BIN_ARGS[@]}"
                printf ')\n'
            )
            eval "$_sandbox_result"

            if [[ -z "$_sandbox_result" || -z "${_h_consumed+set}" ]]; then
                WRAPPER_ERROR="handler '${flag_name}' called exit unexpectedly"
            elif [[ -z "$WRAPPER_ERROR" ]]; then
                for (( _i=0; _i<_h_consumed; _i++ )); do shift; done
                WRAPPED_BIN_ARGS+=("${_h_new_args[@]}")
            fi
            unset _orig_argc _sandbox_result _h_consumed _h_new_args _i
            continue
        fi
    fi

    if [[ -d "$HANDLER_DIR/$arg" ]]; then
        HANDLER_DIR="$HANDLER_DIR/$arg"
    fi
    WRAPPED_BIN_ARGS+=("$arg")
done

if [[ -n "$WRAPPER_ERROR" ]]; then
    echo "binwrap: $WRAPPER_ERROR" >&2
    exit 1
fi

exec command "$BINWRAP_BINARY" "${WRAPPED_BIN_ARGS[@]}"
